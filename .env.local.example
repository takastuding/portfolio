# 本ファイルは `.env.local` の雛形です。
# コピーして `.env.local` を作成し、実際の値を設定してください。
# `.env.local` は `.gitignore` に含まれておりリポジトリには含まれません。

# Supabase (フロント側で使用)
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Google Analytics 4
# Google Analytics の「測定 ID」（例: G-XXXXXXXXXX）を設定してください。
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Resend API キー (Edge Function 側の secret として設定するため、.env.local には不要)
# 以下のコマンドでサーバー側に登録してください:
#   pnpm dlx supabase secrets set RESEND_API_KEY=re_xxxxxxxxx
